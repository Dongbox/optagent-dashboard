{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Dongbox/optagent-benckmarks/results/schema/run-v1.schema.json",
  "title": "OptAgent Benchmark Run Summary",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "run_id",
    "benchmark_group",
    "benchmark_id",
    "family",
    "tier",
    "strategy",
    "strategy_profile",
    "strategy_config",
    "seed",
    "optagent",
    "benchmarks",
    "environment",
    "metrics",
    "artifacts",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "run_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-[0-9]{8}-[0-9]{6}-[a-f0-9]{7,40}$"
    },
    "benchmark_group": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "benchmark_id": {
      "type": "string"
    },
    "family": {
      "type": "string"
    },
    "tier": {
      "type": "string"
    },
    "strategy": {
      "type": "string"
    },
    "strategy_profile": {
      "type": "string"
    },
    "strategy_config": {
      "type": "object",
      "additionalProperties": true
    },
    "seed": {
      "type": "integer"
    },
    "optagent": {
      "type": "object",
      "additionalProperties": true,
      "required": ["version", "commit", "commit_url", "wheel_sha256"],
      "properties": {
        "version": {"type": "string"},
        "commit": {"type": "string"},
        "commit_url": {"type": "string"},
        "wheel_sha256": {"type": "string"}
      }
    },
    "benchmarks": {
      "type": "object",
      "additionalProperties": true,
      "required": ["commit", "commit_url"],
      "properties": {
        "commit": {"type": "string"},
        "commit_url": {"type": "string"}
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": true,
      "required": ["python", "platform", "runner"],
      "properties": {
        "python": {"type": "string"},
        "platform": {"type": "string"},
        "runner": {"type": "string"}
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": true,
      "required": ["status", "feasible", "runtime_ms"],
      "properties": {
        "status": {"type": "string"},
        "feasible": {"type": "boolean"},
        "objective": {"type": ["number", "null"]},
        "best_cost": {"type": ["number", "null"]},
        "reference_cost": {"type": ["number", "null"]},
        "gap_rel": {"type": ["number", "null"]},
        "runtime_ms": {"type": "integer", "minimum": 0},
        "time_to_first_feasible_ms": {"type": ["integer", "null"], "minimum": 0},
        "time_to_best_ms": {"type": ["integer", "null"], "minimum": 0},
        "error_type": {"type": "string"},
        "error_message": {"type": "string"}
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "created_at": {
      "type": "string"
    }
  }
}
